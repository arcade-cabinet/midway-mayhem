{
  "name": "midway-mayhem",
  "version": "0.2.8",
  "private": true,
  "description": "Midway Mayhem: Clown Car Chaos — cockpit-perspective arcade driver",
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:native": "tsc --noEmit && cross-env CAPACITOR=true vite build",
    "preview": "vite preview",
    "cap:sync": "pnpm build:native && cap sync",
    "native:android:debug": "pnpm build:native && cap sync android && cd android && ./gradlew assembleDebug",
    "native:ios:build": "pnpm build:native && cap sync ios && xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Debug -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 16'",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "audit:bundle": "pnpm audit:perf",
    "audit:perf": "pnpm build && tsx scripts/audit-perf.ts",
    "copywasm": "node -e \"const fs=require('fs'),p=require('path');const files=['sql-wasm.wasm','sql-wasm-browser.wasm'];for(const dir of [p.join('public'),p.join('public','assets')]){fs.mkdirSync(dir,{recursive:true});for(const f of files){fs.copyFileSync(require.resolve('sql.js/dist/'+f),p.join(dir,f));}}console.log('copied',files.join(' + '),'→ public/ + public/assets/')\"",
    "predev": "pnpm copywasm",
    "prebuild": "pnpm copywasm",
    "prepreview": "pnpm copywasm",
    "pretest:browser": "pnpm copywasm",
    "pretest:e2e": "pnpm copywasm",
    "pree2e": "pnpm copywasm",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --grep-invert @nightly",
    "e2e:nightly": "playwright test --grep @nightly --grep-invert stability-soak",
    "e2e:stability-soak": "playwright test e2e/stability-soak.spec.ts",
    "e2e:update": "playwright test --update-snapshots",
    "e2e:ui": "playwright test --ui",
    "perf:android": "playwright test --grep @android-perf",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest",
    "test:visual:update": "vitest run --project browser --update",
    "playthrough": "tsx scripts/playthrough-governor.ts",
    "playthrough:self": "tsx scripts/playthrough-governor.ts --self-host",
    "icons": "tsx scripts/generate-icons.ts",
    "screenshots:store": "tsx scripts/generate-store-screenshots.ts",
    "screenshots:store:self": "tsx scripts/generate-store-screenshots.ts --self-host",
    "prescreenshots:store:self": "pnpm copywasm"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "drizzle-orm": "^0.45.2",
    "jeep-sqlite": "^2.8.0",
    "koota": "^0.6.6",
    "postprocessing": "^6.39.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "spessasynth_lib": "^4.2.15",
    "sql.js": "^1.14.1",
    "three": "0.184.0",
    "tone": "^15.1.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "@types/sql.js": "^1.4.11",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "cross-env": "^10.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.0",
      "serialize-javascript": "^7.0.5",
      "react": "19.2.5",
      "react-dom": "19.2.5",
      "three": "0.184.0",
      "@xmldom/xmldom": ">=0.8.13"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
