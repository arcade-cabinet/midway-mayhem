{
  "name": "midway-mayhem",
  "version": "0.1.0",
  "private": true,
  "description": "Midway Mayhem: Clown Car Chaos — cockpit-perspective arcade driver",
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "copywasm": "tsx scripts/copywasm.ts",
    "fetch:soundfonts": "tsx scripts/fetch-soundfonts.ts",
    "predev": "pnpm copywasm",
    "prebuild": "pnpm copywasm",
    "prepreview": "pnpm copywasm",
    "pretest:browser": "pnpm copywasm",
    "pretest:e2e": "pnpm copywasm",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:native": "pnpm copywasm && tsc --noEmit && CAPACITOR=true vite build",
    "preview": "vite preview",
    "start": "vite",
    "cap:sync": "pnpm copywasm && cap sync",
    "native:android:debug": "pnpm build:native && cap sync android && cd android && ./gradlew assembleDebug",
    "native:ios:build": "pnpm build:native && cap sync ios && xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Debug -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 16'",
    "qa:native:android": "bash scripts/native-smoke-android.sh",
    "qa:native:ios": "bash scripts/native-smoke-ios.sh",
    "db:generate": "drizzle-kit generate",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:node && pnpm test:jsdom",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:jsdom": "vitest run --config vitest.jsdom.config.ts",
    "test:watch": "vitest --config vitest.node.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:surfaces:check": "tsx scripts/check-test-surfaces.ts",
    "test:surfaces": "pnpm test:surfaces:check && pnpm test:node && pnpm test:jsdom && pnpm test:browser",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:maestro:doctor": "bash scripts/maestro-doctor.sh",
    "test:maestro": "bash scripts/maestro-smoke.sh",
    "audit:balance": "tsx scripts/run-balance-audit.ts",
    "audit:balance:compare": "tsx scripts/compare-balance-audits.ts",
    "capture:marketing": "tsx scripts/capture-marketing.ts",
    "deploy:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/capacitor": "^3.2.1",
    "@sentry/react": "^10.49.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jeep-sqlite": "^2.8.0",
    "koota": "^0.6.6",
    "postprocessing": "^6.39.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "spessasynth_lib": "^4.2.14",
    "sql.js": "1.11.0",
    "three": "^0.183.2",
    "tone": "^15.1.22",
    "yuka": "^0.7.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "drizzle-kit": "^0.30.6",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.0",
      "serialize-javascript": "^7.0.5",
      "happy-dom": "^20.9.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
